# Google Maps (client-side — restrict to your domain in Google Cloud Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# PayPal (client ID only — no secret needed for client-side SDK)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
# Set PAYPAL_MODE=live in PayPal dashboard when ready for real payments

# EmailJS (all public — safe to expose client-side)
# Sign up free at https://www.emailjs.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx        # booking alert template
NEXT_PUBLIC_EMAILJS_DRIVER_TEMPLATE_ID=template_xxxxxxx  # driver signup template
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# GitHub Pages base path (set automatically in CI — leave blank for local dev)
NEXT_PUBLIC_BASE_PATH=
